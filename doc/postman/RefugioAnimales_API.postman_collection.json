{
	"info": {
		"_postman_id": "a4d3b6f2-8c9e-4a11-b1e2-9d3f8a4b6c7d",
		"name": "RefugioAnimales API",
		"description": "Colección de pruebas para la API REST del Refugio de Animales. Incluye flujos de Autenticación, gestión de Animales y procesos de Adopción.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "1. Autenticación (Auth Service)",
			"item": [
				{
					"name": "Login de Usuario",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"pm.environment.set(\"jwt_token\", jsonData.token);"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"admin@refugio.es\",\n    \"password\": \"admin123\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/v1/auth/login",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"v1",
								"auth",
								"login"
							]
						}
					}
				}
			]
		},
		{
			"name": "2. Inventario Vivo (Backend Service)",
			"item": [
				{
					"name": "Listar Animales Disponibles",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/v1/animales?estado=DISPONIBLE",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"v1",
								"animales"
							],
							"query": [
								{
									"key": "estado",
									"value": "DISPONIBLE"
								}
							]
						}
					}
				},
				{
					"name": "Obtener Ficha Animal por ID",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/v1/animales/1",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"v1",
								"animales",
								"1"
							]
						}
					}
				}
			]
		},
		{
			"name": "3. Adopciones Privadas (Backend Service)",
			"item": [
				{
					"name": "Enviar Solicitud de Adopción",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{jwt_token}}",
									"type": "string"
								}
							]
						},
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"animalId\": 1,\n    \"comentario\": \"Me encantaría adoptar a Luna. Tengo una casa con jardín amplio y experiencia previa con labradores.\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/v1/solicitudes-adopcion/directa",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"v1",
								"solicitudes-adopcion",
								"directa"
							]
						}
					}
				}
			]
		}
	],
	"event": [
		{
			"listen": "prerequest",
			"script": {
				"type": "text/javascript",
				"exec": [
					""
				]
			}
		},
		{
			"listen": "test",
			"script": {
				"type": "text/javascript",
				"exec": [
					""
				]
			}
		}
	],
	"variable": [
		{
			"key": "base_url",
			"value": "http://localhost:8080",
			"type": "string"
		},
		{
			"key": "jwt_token",
			"value": "",
			"type": "string"
		}
	]
}
