# ─── Maven ───────────────────────────────────────────────────────────────────
# Carpetas de compilación de TODOS los módulos
**/target/
**/pom.xml.tag
**/pom.xml.releaseBackup
**/pom.xml.versionsBackup
**/pom.xml.next
**/release.properties
**/dependency-reduced-pom.xml
**/buildNumber.properties
**/.mvn/timing.properties

# Maven Wrapper jar (solo se ignora el binario, no los scripts)
**/mvnw
**/mvnw.cmd
**/.mvn/wrapper/maven-wrapper.jar

# ─── Spring Boot ─────────────────────────────────────────────────────────────
application-local.properties
application-local.yml
**/application-local.properties
**/application-local.yml

# ─── Variables de entorno y secretos ─────────────────────────────────────────
.env
.env.local
.env.*.local

# Certificados y keystores — contienen claves privadas, NO subir a Git
**/keystore.p12
**/keystore.jks
**/*.p12
**/*.jks
**/*.pfx
**/*.pem
**/*.key
**/*.crt
**/*.cer

# ─── Logs ────────────────────────────────────────────────────────────────────
*.log
**/logs/
spring.log

# ─── Eclipse / STS ───────────────────────────────────────────────────────────
.apt_generated
.classpath
.factorypath
.project
.settings/
.springBeans
.sts4-cache/

# ─── IntelliJ IDEA ───────────────────────────────────────────────────────────
.idea/
*.iws
*.iml
*.ipr
out/

# ─── NetBeans ────────────────────────────────────────────────────────────────
/nbproject/private/
/nbbuild/
/dist/
/nbdist/
/.nb-gradle/
build/

# ─── VS Code ─────────────────────────────────────────────────────────────────
# Se ignoran los settings personales pero SE INCLUYEN launch.json y tasks.json
.vscode/settings.json
.vscode/extensions.json
.vscode/*.code-snippets
.vscode/launch.json
.vscode/tasks.json

# ─── Sistema Operativo (Windows) ─────────────────────────────────────────────
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.lnk
*:Zone.Identifier

# ─── Sistema Operativo (macOS) ───────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
._*

# ─── JVM / Java ──────────────────────────────────────────────────────────────
*.class
hs_err_pid*
replay_pid*
