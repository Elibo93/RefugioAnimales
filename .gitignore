**/mvnw.cmd
**/.mvn/wrapper/maven-wrapper.jar

# ─── Spring Boot ─────────────────────────────────────────────────────────────
application-local.properties
application-local.yml
**/application-local.properties
**/application-local.yml

# ─── Variables de entorno y secretos ─────────────────────────────────────────
# ⚠️ NUNCA subir .env a Git — contiene secretos
.env
.env.local
.env.*.local
# .env.example sí puede subirse (sin valores reales)
!.env.example

# Certificados y keystores — contienen claves privadas, NO subir a Git
**/keystore.p12
**/keystore.jks
# **/*.p12 -> Permitido temporalmente
**/*.jks
**/*.pfx
!api-gateway/src/main/resources/keystore.p12
**/*.pem
**/*.key
**/*.crt
**/*.cer

# ─── Logs ────────────────────────────────────────────────────────────────────
*.log
**/*.log
**/*.log.*
**/logs/
spring.log


